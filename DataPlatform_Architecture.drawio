        </mxCell>

        <!-- Phase 1 -->
        <mxCell id="p1" value="Phase 1 – MVP Foundation&#xa;Weeks 1–6" style="rounded=1;fillColor=#2563EB;strokeColor=#1E3A8A;fontColor=#FFFFFF;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="672" width="330" height="54" as="geometry" />
        </mxCell>
        <mxCell id="p1-items" value="• GCS bucket structure + lifecycle policies&#xa;• Dataproc cluster + auto-scaling policy&#xa;• StorageClient + SparkSession abstractions&#xa;• 3 pilot source tables (1 dim, 2 fact)&#xa;• Account Layer – Ground segment, daily only&#xa;• pipeline_run_log + step_execution_log tables&#xa;• Basic Airflow DAG + email alerting&#xa;• CI/CD pipeline for dev/staging/prod" style="text;html=1;fontSize=9;fillColor=none;strokeColor=none;fontColor=#374151;align=left;" vertex="1" parent="1">
          <mxGeometry x="80" y="730" width="330" height="112" as="geometry" />
        </mxCell>

        <!-- Phase 2 -->
        <mxCell id="p2" value="Phase 2 – Core Platform&#xa;Weeks 7–14" style="rounded=1;fillColor=#059669;strokeColor=#047857;fontColor=#FFFFFF;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="450" y="672" width="330" height="54" as="geometry" />
        </mxCell>
        <mxCell id="p2-items" value="• All 4 segments for Account Layer&#xa;• Facility + Country Layers&#xa;• DQ framework: schema, nulls, volume, RI&#xa;• Config-driven transformation engine&#xa;• Incremental load: CDC + snapshot delta&#xa;• Centralised logging → BigQuery sink&#xa;• Grafana / Cloud Monitoring dashboard&#xa;• Slack + PagerDuty alert integration" style="text;html=1;fontSize=9;fillColor=none;strokeColor=none;fontColor=#374151;align=left;" vertex="1" parent="1">
          <mxGeometry x="450" y="730" width="330" height="112" as="geometry" />
        </mxCell>

        <!-- Phase 3 -->
        <mxCell id="p3" value="Phase 3 – Full Production&#xa;Weeks 15–22" style="rounded=1;fillColor=#EA580C;strokeColor=#C2410C;fontColor=#FFFFFF;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="820" y="672" width="330" height="54" as="geometry" />
        </mxCell>
        <mxCell id="p3-items" value="• Global Layer + all monthly pipelines (64 tables)&#xa;• Full DQ: drift detection + completeness scoring&#xa;• OpenLineage + Marquez data lineage&#xa;• Column-level security + PII masking&#xa;• Backfill framework with UI + progress tracking&#xa;• Performance tuning: AQE, Z-order, broadcasts&#xa;• Disaster recovery runbooks + chaos tests" style="text;html=1;fontSize=9;fillColor=none;strokeColor=none;fontColor=#374151;align=left;" vertex="1" parent="1">
          <mxGeometry x="820" y="730" width="330" height="112" as="geometry" />
        </mxCell>

        <!-- Phase 4 -->
        <mxCell id="p4" value="Phase 4 – Cloud Portability&#xa;Weeks 23–28" style="rounded=1;fillColor=#7C3AED;strokeColor=#5B21B6;fontColor=#FFFFFF;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1190" y="672" width="330" height="54" as="geometry" />
        </mxCell>
        <mxCell id="p4-items" value="• Validate abstractions on AWS (EMR/S3/MWAA)&#xa;• ADRs, API contracts, operational runbooks&#xa;• SLA monitoring + auto-escalation&#xa;• Load test at 10× peak volume&#xa;• Security review + IAM audit + compliance&#xa;• Production go-live + 4-week hypercare" style="text;html=1;fontSize=9;fillColor=none;strokeColor=none;fontColor=#374151;align=left;" vertex="1" parent="1">
          <mxGeometry x="1190" y="730" width="330" height="112" as="geometry" />
        </mxCell>

        <!-- Phase arrows -->
        <mxCell id="pa1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#374151;strokeWidth=2;" edge="1" source="p1" target="p2" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="pa2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#374151;strokeWidth=2;" edge="1" source="p2" target="p3" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="pa3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#374151;strokeWidth=2;" edge="1" source="p3" target="p4" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Timeline bar -->
        <mxCell id="timeline" value="" style="rounded=1;fillColor=#E2E8F0;strokeColor=#94A3B8;" vertex="1" parent="1">
          <mxGeometry x="80" y="880" width="1440" height="16" as="geometry" />
        </mxCell>
        <mxCell id="tl1" value="" style="rounded=1;fillColor=#2563EB;strokeColor=#1E3A8A;" vertex="1" parent="1">
          <mxGeometry x="80" y="880" width="308" height="16" as="geometry" />
        </mxCell>
        <mxCell id="tl2" value="" style="rounded=0;fillColor=#059669;strokeColor=#047857;" vertex="1" parent="1">
          <mxGeometry x="388" y="880" width="336" height="16" as="geometry" />
        </mxCell>
        <mxCell id="tl3" value="" style="rounded=0;fillColor=#EA580C;strokeColor=#C2410C;" vertex="1" parent="1">
          <mxGeometry x="724" y="880" width="336" height="16" as="geometry" />
        </mxCell>
        <mxCell id="tl4" value="" style="rounded=1;fillColor=#7C3AED;strokeColor=#5B21B6;" vertex="1" parent="1">
          <mxGeometry x="1060" y="880" width="460" height="16" as="geometry" />
        </mxCell>
        <mxCell id="tl-lbl" value="Week 1                              Week 6          Week 14                   Week 22              Week 28" style="text;html=1;fontSize=9;fillColor=none;strokeColor=none;fontColor=#374151;align=left;" vertex="1" parent="1">
          <mxGeometry x="80" y="898" width="1440" height="16" as="geometry" />
        </mxCell>

        <!-- Legend note -->
        <mxCell id="legend" value="✦ All storage paths resolved from environment_config — no hardcoded cloud URIs in business logic code&#xa;✦ Same Docker image runs locally, on Dataproc, EMR, or Databricks via CLOUD_PROVIDER environment variable&#xa;✦ Airflow DAGs use provider-agnostic operators; cloud-specific operators isolated in the abstraction layer only" style="rounded=1;fillColor=#1B3A6B;strokeColor=#1B3A6B;fontColor=#FFFFFF;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="80" y="930" width="1440" height="60" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
