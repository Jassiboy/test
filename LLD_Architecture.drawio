    <!-- SECTION D: SCHEMA REGISTRY + WATERMARK STRATEGY              -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <mxCell id="schema_band" value="D.  Schema Registry &amp; Watermark Checkpoint Strategy" style="rounded=1;arcSize=2;fillColor=#E0F2F1;strokeColor=#00695C;strokeWidth=3;fontSize=14;fontStyle=1;fontColor=#004D40;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="50" y="2080" width="2100" height="350" as="geometry"/>
    </mxCell>

    <mxCell id="schema_flow" value="SCHEMA REGISTRY FLOW&#xa;──────────────────────────────&#xa;Dev adds new column to src_table_1&#xa;         │&#xa;         ▼&#xa;New schema file created:&#xa;gs://config/schema-registry/&#xa;  src_table_1/v2/schema.avsc&#xa;         │&#xa;         ▼&#xa;CI/CD runs schema_migration.py:&#xa;  IF is_breaking_change = FALSE:&#xa;    BQ ALTER TABLE ADD COLUMN&#xa;    UPDATE schema_version SET is_current=FALSE (v1)&#xa;    INSERT schema_version (v2, is_current=TRUE)&#xa;  ELSE:&#xa;    Require manual approval gate&#xa;    Create migration DAG for backfill&#xa;         │&#xa;         ▼&#xa;Dataflow Flex Template updated&#xa;to read new schema version" style="rounded=1;fillColor=#E0F7FA;strokeColor=#00695C;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
      <mxGeometry x="70" y="2115" width="380" height="290" as="geometry"/>
    </mxCell>

    <mxCell id="watermark_flow" value="WATERMARK CHECKPOINT STRATEGY&#xa;──────────────────────────────────────&#xa;TABLE: pipeline_runs stores per-run watermarks&#xa;&#xa;Before each run:&#xa;  SELECT watermark_end&#xa;  FROM pipeline_runs&#xa;  WHERE table_name = 'src_table_1'&#xa;    AND status = 'SUCCESS'&#xa;  ORDER BY dag_run_date DESC LIMIT 1;&#xa;  → Returns: '2026-06-04T23:59:59Z'&#xa;&#xa;Dataflow job reads:&#xa;  WHERE updated_at &gt; '2026-06-04T23:59:59Z'&#xa;    AND updated_at &lt;= CURRENT_TIMESTAMP()&#xa;&#xa;After successful run:&#xa;  UPDATE pipeline_runs&#xa;  SET watermark_end = CURRENT_TIMESTAMP(),&#xa;      status = 'SUCCESS'&#xa;  WHERE run_id = current_run_id;&#xa;&#xa;FAILURE RECOVERY:&#xa;  Rerun uses same watermark_start&#xa;  (never advances watermark on failure)" style="rounded=1;fillColor=#E8F5E9;strokeColor=#1B5E20;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
      <mxGeometry x="490" y="2115" width="400" height="290" as="geometry"/>
    </mxCell>

    <mxCell id="where_guide" value="WHERE TO CREATE EACH TABLE — QUICK REFERENCE&#xa;────────────────────────────────────────────────────────────────────────────&#xa;TABLE                  DATASET           PARTITION         CLUSTER             PURPOSE&#xa;──────────────────────────────────────────────────────────────────────────────&#xa;pipeline_config        bq_metadata       NONE (small)      —                   Master config KV store&#xa;table_config           bq_metadata       NONE (small)      layer, table_name   Per-table ingestion settings&#xa;pipeline_runs          bq_metadata       dag_run_date      layer, status       Primary execution log&#xa;dq_results             bq_metadata       dag_run_date      layer, table_name   DQ check results&#xa;quarantine             bq_metadata       dag_run_date      source_table        Rejected records&#xa;reconciliation         bq_metadata       dag_run_date      source_layer        Layer row count recon&#xa;alert_log              bq_metadata       created_at        severity, layer     All alerts fired&#xa;schema_version         bq_metadata       NONE              table_name          Schema history&#xa;lineage                bq_metadata       dag_run_date      source_table        Data lineage&#xa;──────────────────────────────────────────────────────────────────────────────&#xa;_dq_results (per-layer) bq_silver_account  processing_date  table_name         Silver-level DQ detail&#xa;                        bq_silver_global&#xa;                        bq_gold_facility&#xa;                        bq_gold_country&#xa;ALL of the above created via: terraform apply → module/bigquery/metadata_tables.tf" style="rounded=1;fillColor=#FFFDE7;strokeColor=#F57F17;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
      <mxGeometry x="930" y="2115" width="1175" height="290" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel>
