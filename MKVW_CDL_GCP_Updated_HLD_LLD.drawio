        <!-- Retry config callout -->
        <mxCell id="retry-note" value="&lt;b&gt;Airflow Retry Config:&lt;/b&gt;&lt;br&gt;retries = 3&lt;br&gt;retry_delay = 5 min&lt;br&gt;exponential_backoff = True&lt;br&gt;max_retry_delay = 60 min&lt;br&gt;email_on_failure = True&lt;br&gt;sla = 4 hours" style="rounded=1;fillColor=#FFFDE7;strokeColor=#F57F17;fontSize=9;align=left;" parent="1" vertex="1">
          <mxGeometry x="70" y="1145" width="200" height="115" as="geometry" />
        </mxCell>
        <mxCell id="sla-note" value="&lt;b&gt;SLA Miss → Pub/Sub Alert&lt;/b&gt;&lt;br&gt;Cloud Monitoring policy fires&lt;br&gt;if DAG run &gt; sla_hours&lt;br&gt;(defined per table in table_config)&lt;br&gt;→ alert_log INSERT&lt;br&gt;→ PagerDuty P2" style="rounded=1;fillColor=#FCE4EC;strokeColor=#C62828;fontSize=9;align=left;" parent="1" vertex="1">
          <mxGeometry x="290" y="1145" width="220" height="115" as="geometry" />
        </mxCell>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- SECTION D: Reinstatement Logic -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <mxCell id="reinstate-section" value="D.  Reinstatement Logic — sp_reinstate_pipeline + reinstate_pipeline_dag" style="rounded=1;arcSize=2;fillColor=#FFF8E1;strokeColor=#F57F17;strokeWidth=3;fontSize=14;fontStyle=1;fontColor=#E65100;verticalAlign=top;" parent="1" vertex="1">
          <mxGeometry x="50" y="1350" width="2110" height="550" as="geometry" />
        </mxCell>

        <!-- Reinstatement flow steps -->
        <mxCell id="r1" value="1. DETECT FAILURE&lt;br&gt;on_failure_callback&lt;br&gt;OR monitoring alert&lt;br&gt;OR manual trigger" style="rounded=1;fillColor=#FFCC80;strokeColor=#E65100;fontSize=9;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="70" y="1390" width="165" height="75" as="geometry" /></mxCell>
        <mxCell id="r2" value="2. QUERY pipeline_runs&lt;br&gt;Find: failed run_id,&lt;br&gt;layer, table_name,&lt;br&gt;watermark_start,&lt;br&gt;attempt_number" style="rounded=1;fillColor=#FFCC80;strokeColor=#E65100;fontSize=9;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="265" y="1390" width="165" height="75" as="geometry" /></mxCell>
        <mxCell id="r3" value="3. CHECK BUDGET&lt;br&gt;attempt &lt; max_retry?&lt;br&gt;YES → auto retry&lt;br&gt;NO → HALT +&lt;br&gt;P1 alert" style="rounded=1;fillColor=#FFCC80;strokeColor=#E65100;fontSize=9;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="460" y="1390" width="165" height="75" as="geometry" /></mxCell>
        <mxCell id="r4" value="4. DELETE PARTITION&lt;br&gt;BQ DELETE WHERE&lt;br&gt;processing_date =&lt;br&gt;run_date&lt;br&gt;(idempotent)" style="rounded=1;fillColor=#FFCC80;strokeColor=#E65100;fontSize=9;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="655" y="1390" width="165" height="75" as="geometry" /></mxCell>
        <mxCell id="r5" value="5. NEW run_id&lt;br&gt;INSERT pipeline_runs&lt;br&gt;status=RUNNING&lt;br&gt;attempt_number++&lt;br&gt;parent_run_id=orig" style="rounded=1;fillColor=#FFCC80;strokeColor=#E65100;fontSize=9;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="850" y="1390" width="165" height="75" as="geometry" /></mxCell>
        <mxCell id="r6" value="6. RERUN TASK&lt;br&gt;Same watermark_start&lt;br&gt;Airflow TriggerDag&lt;br&gt;or BQ job submit" style="rounded=1;fillColor=#FFCC80;strokeColor=#E65100;fontSize=9;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="1045" y="1390" width="165" height="75" as="geometry" /></mxCell>
        <mxCell id="r7" value="7. LOG RESULT&lt;br&gt;UPDATE pipeline_runs&lt;br&gt;status=SUCCESS/FAILED&lt;br&gt;completed_at, bq_job_id&lt;br&gt;watermark_end" style="rounded=1;fillColor=#FFCC80;strokeColor=#E65100;fontSize=9;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="1240" y="1390" width="165" height="75" as="geometry" /></mxCell>
        <mxCell id="r8" value="8. RESUME DOWNSTREAM&lt;br&gt;Airflow clears blocked&lt;br&gt;tasks per depends_on&lt;br&gt;in table_config&lt;br&gt;Pipeline continues" style="rounded=1;fillColor=#A5D6A7;strokeColor=#1B5E20;fontSize=9;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="1435" y="1390" width="165" height="75" as="geometry" /></mxCell>
        <mxCell id="r-halt" value="HALT PATH&lt;br&gt;Max retries exhausted&lt;br&gt;INSERT alert_log P1&lt;br&gt;Pub/Sub → PagerDuty&lt;br&gt;Manual intervention" style="rounded=1;fillColor=#FFCDD2;strokeColor=#B71C1C;fontSize=9;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="460" y="1510" width="165" height="75" as="geometry" /></mxCell>

        <mxCell id="e-r12" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#E65100;strokeWidth=2;" edge="1" source="r1" target="r2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-r23" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#E65100;strokeWidth=2;" edge="1" source="r2" target="r3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-r34" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#E65100;strokeWidth=2;" edge="1" source="r3" target="r4" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="542" y="1490"/><mxPoint x="738" y="1490"/></Array></mxGeometry></mxCell>
        <mxCell id="e-r45" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#E65100;strokeWidth=2;" edge="1" source="r4" target="r5" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-r56" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#E65100;strokeWidth=2;" edge="1" source="r5" target="r6" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-r67" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#E65100;strokeWidth=2;" edge="1" source="r6" target="r7" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-r78" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#1B5E20;strokeWidth=2;" edge="1" source="r7" target="r8" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-r3h" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#B71C1C;strokeWidth=2;dashed=1;" edge="1" source="r3" target="r-halt" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Partial Layer Reinstatement table -->
        <mxCell id="partial-title" value="&lt;b&gt;Partial Layer Reinstatement Scope&lt;/b&gt;" style="text;html=1;fillColor=none;strokeColor=none;fontSize=12;fontStyle=1;fontColor=#1A56A0;" parent="1" vertex="1"><mxGeometry x="70" y="1610" width="400" height="25" as="geometry" /></mxCell>
        <mxCell id="p-hdr" value="Layer That Failed" style="rounded=1;fillColor=#1A56A0;strokeColor=#1A56A0;fontColor=#fff;fontSize=10;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="70" y="1638" width="195" height="30" as="geometry" /></mxCell>
        <mxCell id="p-hdr2" value="Layers to Reinstate (in order)" style="rounded=1;fillColor=#1A56A0;strokeColor=#1A56A0;fontColor=#fff;fontSize=10;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="270" y="1638" width="420" height="30" as="geometry" /></mxCell>
        <mxCell id="p1a" value="Bronze (Ingestion)" style="rounded=1;fillColor=#FFEBEE;strokeColor=#B71C1C;fontSize=9;" parent="1" vertex="1"><mxGeometry x="70" y="1673" width="195" height="28" as="geometry" /></mxCell>
        <mxCell id="p1b" value="Bronze → Account → Global → Facility → Country  (ALL 5 layers)" style="rounded=1;fillColor=#FFEBEE;strokeColor=#B71C1C;fontSize=9;align=left;" parent="1" vertex="1"><mxGeometry x="270" y="1673" width="420" height="28" as="geometry" /></mxCell>
        <mxCell id="p2a" value="Silver — Account" style="rounded=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=9;" parent="1" vertex="1"><mxGeometry x="70" y="1706" width="195" height="28" as="geometry" /></mxCell>
        <mxCell id="p2b" value="Account → Global → Facility → Country  (4 layers)" style="rounded=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=9;align=left;" parent="1" vertex="1"><mxGeometry x="270" y="1706" width="420" height="28" as="geometry" /></mxCell>
        <mxCell id="p3a" value="Silver — Global" style="rounded=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=9;" parent="1" vertex="1"><mxGeometry x="70" y="1739" width="195" height="28" as="geometry" /></mxCell>
        <mxCell id="p3b" value="Global → Facility → Country  (3 layers)" style="rounded=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=9;align=left;" parent="1" vertex="1"><mxGeometry x="270" y="1739" width="420" height="28" as="geometry" /></mxCell>
        <mxCell id="p4a" value="Gold — Facility" style="rounded=1;fillColor=#F1F8E9;strokeColor=#33691E;fontSize=9;" parent="1" vertex="1"><mxGeometry x="70" y="1772" width="195" height="28" as="geometry" /></mxCell>
        <mxCell id="p4b" value="Facility → Country  (2 layers)" style="rounded=1;fillColor=#F1F8E9;strokeColor=#33691E;fontSize=9;align=left;" parent="1" vertex="1"><mxGeometry x="270" y="1772" width="420" height="28" as="geometry" /></mxCell>
        <mxCell id="p5a" value="Gold — Country" style="rounded=1;fillColor=#E8F5E9;strokeColor=#1B5E20;fontSize=9;" parent="1" vertex="1"><mxGeometry x="70" y="1805" width="195" height="28" as="geometry" /></mxCell>
        <mxCell id="p5b" value="Country only  (1 layer — skip all upstream)" style="rounded=1;fillColor=#E8F5E9;strokeColor=#1B5E20;fontSize=9;align=left;" parent="1" vertex="1"><mxGeometry x="270" y="1805" width="420" height="28" as="geometry" /></mxCell>

        <!-- Watermark Strategy -->
        <mxCell id="wm-box" value="&lt;b&gt;Watermark Checkpoint Strategy&lt;/b&gt;&lt;br&gt;──────────────────────────────────────────────&lt;br&gt;START of run: SELECT MAX(watermark_end) FROM pipeline_runs&lt;br&gt;    WHERE table_name=@tbl AND status='SUCCESS'&lt;br&gt;    ORDER BY dag_run_date DESC LIMIT 1;&lt;br&gt;&lt;br&gt;Dataflow reads: WHERE updated_at &gt; watermark_start&lt;br&gt;                 AND updated_at &lt;= CURRENT_TIMESTAMP()&lt;br&gt;&lt;br&gt;END of run (SUCCESS only):&lt;br&gt;  UPDATE pipeline_runs SET watermark_end=@max_seen, status='SUCCESS'&lt;br&gt;&lt;br&gt;FAILURE: watermark_end never written → next rerun uses same watermark_start&lt;br&gt;         (prevents data gaps AND prevents duplicates)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#1B5E20;fontSize=9;verticalAlign=top;align=left;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="730" y="1600" width="700" height="240" as="geometry" />
        </mxCell>

        <!-- DQ Framework detail -->
        <mxCell id="dq-detail" value="&lt;b&gt;DQ Framework — Rule Tiers&lt;/b&gt;&lt;br&gt;──────────────────────────────────────&lt;br&gt;TIER 1 — CRITICAL (action: HALT)&lt;br&gt;  Null checks on PKs, row count &gt; 0,&lt;br&gt;  schema match, duplicate PKs&lt;br&gt;  → Stop pipeline, P1 alert, quarantine batch&lt;br&gt;&lt;br&gt;TIER 2 — WARNING (action: CONTINUE)&lt;br&gt;  Referential integrity, null rates,&lt;br&gt;  value range checks&lt;br&gt;  → Log to dq_results, flag records&lt;br&gt;&lt;br&gt;TIER 3 — INFORMATIONAL (action: LOG_ONLY)&lt;br&gt;  Statistical drift, cardinality checks&lt;br&gt;  → Trend dashboard only&lt;br&gt;&lt;br&gt;Rules stored in:&lt;br&gt;  gs://[proj]-config/dq-rules/&lt;br&gt;  bronze_rules.yaml&lt;br&gt;  silver_account_rules.yaml&lt;br&gt;  silver_global_rules.yaml&lt;br&gt;  gold_facility_rules.yaml&lt;br&gt;  gold_country_rules.yaml" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F57F17;fontSize=9;verticalAlign=top;align=left;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="1460" y="1390" width="300" height="460" as="geometry" />
        </mxCell>

        <!-- Terraform placement guide -->
        <mxCell id="tf-guide" value="&lt;b&gt;Terraform Resource Placement&lt;/b&gt;&lt;br&gt;──────────────────────────────────────────&lt;br&gt;bq_metadata dataset       → modules/bigquery/datasets.tf&lt;br&gt;All metadata tables       → modules/bigquery/metadata_tables.tf&lt;br&gt;sp_reinstate_pipeline     → modules/bigquery/routines.tf&lt;br&gt;Silver/Gold datasets      → modules/bigquery/datasets.tf&lt;br&gt;GCS buckets               → modules/gcs/buckets.tf&lt;br&gt;Cloud Composer env        → modules/composer/environment.tf&lt;br&gt;Dataflow Flex Templates   → modules/dataflow/templates.tf&lt;br&gt;Cloud Monitoring alerts   → modules/monitoring/alert_policies.tf&lt;br&gt;Secret Manager secrets    → modules/security/secrets.tf&lt;br&gt;IAM bindings              → modules/iam/bindings.tf&lt;br&gt;Cloud Build triggers      → modules/cicd/cloudbuild.tf" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3949AB;fontSize=9;verticalAlign=top;align=left;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="1790" y="1390" width="360" height="460" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

</mxfile>
